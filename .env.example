# Application (production deploy: APP_ENV=production)
APP_ENV=development

# CORS — only needed when frontend and API use different origins/ports.
# Browser via :4173 with server.js proxy can leave these unset.
# Example: CORS_ORIGINS=http://192.168.1.10:4173,http://192.168.1.10:8888
# If unset when APP_ENV=production, backend allows https?://.* (LAN-friendly).
# CORS_ORIGINS=
# CORS_ALLOW_ORIGIN_REGEX=

# Admin (required in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# JWT (required in production — use a long random string)
JWT_SECRET=change-me-in-production

# LLM API keys (optional — enable AI predictions)
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=

# Data sources
ODDS_API_KEY=
# Required for World Cup live/finished scores on dashboard (free tier: football-data.org)
FOOTBALL_DATA_API_KEY=

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Crawler proxy (optional — The Odds API etc.; sporttery.cn uses direct by default)
CRAWLER_PROXY=

# --- Sporttery.cn (国内 / 海外) ---
# 国内电脑部署（推荐）：
#   SPORTTERY_DIRECT=true
#   不要设置 SPORTTERY_PROXY；Clash 规则 sporttery.cn → DIRECT
# 海外服务器部署：
#   SPORTTERY_PROXY=http://127.0.0.1:7890  （国内 HTTP 中转）
#   Clash 规则 sporttery.cn → 中国大陆节点（见 deploy/clash-sporttery-rules.yaml）
SPORTTERY_DIRECT=true
# SPORTTERY_PROXY=

# Browser fallback when httpx still gets 567 (requires: playwright install chromium)
SPORTTERY_PLAYWRIGHT_FALLBACK=true
